#!/usr/bin/env bash
set -euo pipefail

script_dir="${HOME}/.local/share/claude-sessions-cli"
# bun resolves symlinks, so node_modules must be next to the real index.tsx
real_script="$(readlink -f "${script_dir}/index.tsx")"
real_dir="$(dirname "${real_script}")"

if [ ! -d "${real_dir}/node_modules" ]; then
  echo "Installing dependencies..." >&2
  (cd "${real_dir}" && bun install)
fi

exec bun run "${script_dir}/index.tsx" "$@"
