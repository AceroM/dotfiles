#!/usr/bin/env bash
set -euo pipefail

bin_path="$(readlink -f "${BASH_SOURCE[0]}")"
local_dir="$(dirname "$(dirname "${bin_path}")")"
script_dir="${local_dir}/share/diffshub-cli"
# bun resolves symlinks, so node_modules must be next to the real index.ts
real_script="$(readlink -f "${script_dir}/index.ts")"
real_dir="$(dirname "${real_script}")"

if [ ! -d "${real_dir}/node_modules" ]; then
  echo "Installing dependencies..." >&2
  (cd "${real_dir}" && bun install --frozen-lockfile)
fi

exec bun "${script_dir}/index.ts" "$@"
