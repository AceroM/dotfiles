#!/usr/bin/env bash
set -euo pipefail

session="agents"
port="${1:-3333}"
script_dir="${HOME}/.local/share/agents-cli"

if tmux -L bg has-session -t "$session" 2>/dev/null; then
  echo "agents session already running — attaching"
  exec tmux -L bg attach-session -t "$session"
fi

tmux -L bg new-session -d -s "$session" -n "$session" "bun run ${script_dir}/index.ts ${port}"
echo "agents server started in tmux session '${session}' on port ${port}"
echo "  attach: tmux -L bg attach -t ${session}"
echo "  kill:   tmux -L bg kill-session -t ${session}"
