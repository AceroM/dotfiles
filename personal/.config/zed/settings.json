{
  "agent_servers": {
    "claude-acp": {
      "default_config_options": {
        "mode": "bypassPermissions",
      },
      "favorite_config_option_values": {
        "mode": ["bypassPermissions"],
      },
      "type": "registry",
    },
  },
  "cli_default_open_behavior": "new_window",
  "project_panel": {
    "dock": "right",
  },
  "outline_panel": {
    "dock": "right",
  },
  "collaboration_panel": {
    "dock": "right",
  },
  "git_panel": {
    "dock": "right",
  },
  "autosave": "on_focus_change",
  "git": {
    "inline_blame": {
      "enabled": false,
    },
  },
  "agent": {
    "dock": "left",
    "tool_permissions": {
      "default": "allow",
    },
    "default_profile": "write",
    "default_model": {
      "effort": "high",
      "enable_thinking": true,
      "provider": "zed.dev",
      "model": "claude-opus-4-7",
    },
    "favorite_models": [],
    "model_parameters": [],
  },
  "languages": {
    "TypeScript": {
      "language_servers": ["tsgo"],
      "format_on_save": "on",
      "prettier": { "allowed": false },
      "formatter": [{ "language_server": { "name": "oxfmt" } }],
    },
    "TSX": {
      "language_servers": ["...", "!eslint", "oxfmt"],
      "format_on_save": "on",
      "prettier": { "allowed": false },
      "formatter": [{ "language_server": { "name": "oxfmt" } }],
    },
    "JavaScript": {
      "language_servers": ["...", "!eslint", "oxfmt"],
      "format_on_save": "on",
      "prettier": { "allowed": false },
      "formatter": [{ "language_server": { "name": "oxfmt" } }],
    },
    "JSON": {
      "format_on_save": "on",
      "prettier": { "allowed": false },
      "formatter": [{ "language_server": { "name": "oxfmt" } }],
    },
    "JSONC": {
      "format_on_save": "on",
      "prettier": { "allowed": false },
      "formatter": [{ "language_server": { "name": "oxfmt" } }],
    },
  },
  "lsp": {
    "tsgo": {
      "settings": {
        "package_version": "7.0.0-dev.20251029.1",
      },
    },
  },
  "relative_line_numbers": "enabled",
  "edit_predictions": {
    "provider": "zed",
    "mode": "eager",
    "copilot": {
      "proxy": null,
      "proxy_no_verify": null,
    },
  },
  "terminal": {
    "option_as_meta": true,
  },
  "vim_mode": true,
  "ui_font_size": 14,
  "buffer_font_size": 14,
  "theme": {
    "light": "One Light",
    "dark": "One Dark",
    "mode": "system",
  },
}
