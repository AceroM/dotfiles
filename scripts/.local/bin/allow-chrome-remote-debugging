#!/usr/bin/env bash
set -euo pipefail

interval="${1:-3}"

usage() {
  cat <<'USAGE'
Usage: allow-chrome-remote-debugging [interval_seconds]

Poll for Chrome's "Allow remote debugging?" prompt and click Allow.
Defaults to polling every 3 seconds. Press Ctrl-C to stop.

Note: the prompt is a Chrome Views *sheet*, not a normal macOS window, and its
buttons expose their label via AXDescription (not AXTitle). We match the button
whose description is "Allow" and press it. Requires Accessibility permission for
whichever terminal app runs this script (System Settings > Privacy & Security >
Accessibility).
USAGE
}

case "${interval}" in
  -h|--help)
    usage
    exit 0
    ;;
esac

if ! [[ "${interval}" =~ ^[0-9]+([.][0-9]+)?$ ]] || [[ "${interval}" == "0" || "${interval}" == "0.0" ]]; then
  echo "interval_seconds must be a positive number" >&2
  exit 2
fi

echo "Polling every ${interval}s for Chrome's remote debugging prompt. Press Ctrl-C to stop."

while true; do
  result="$(
    /usr/bin/osascript <<'APPLESCRIPT'
on pressAllowInSheet(theSheet, procName)
  tell application "System Events"
    repeat with e in (entire contents of theSheet)
      try
        if (role of e as text) is "AXButton" and (description of e as text) is "Allow" then
          -- Bring Chrome forward so the sheet is key, then press Allow.
          tell application "Google Chrome" to activate
          perform action "AXPress" of e
          return "clicked " & procName
        end if
      end try
    end repeat
  end tell
  return ""
end pressAllowInSheet

tell application "System Events"
  set chromeProcessNames to {"Google Chrome", "Google Chrome Beta", "Google Chrome Canary", "Chromium", "Chrome for Testing", "Google Chrome for Testing"}

  repeat with chromeProcessName in chromeProcessNames
    if exists process chromeProcessName then
      tell process chromeProcessName
        repeat with chromeWindow in windows
          if exists sheet 1 of chromeWindow then
            set sheetName to ""
            try
              set sheetName to name of sheet 1 of chromeWindow as text
            end try
            if sheetName contains "Allow remote debugging" then
              set clicked to my pressAllowInSheet(sheet 1 of chromeWindow, chromeProcessName as text)
              if clicked is not "" then return clicked
            end if
          end if
        end repeat
      end tell
    end if
  end repeat
end tell

return "not found"
APPLESCRIPT
  )" || result="osascript failed"

  if [[ "${result}" == clicked* ]]; then
    printf '%s\n' "${result}"
  elif [[ "${result}" == "osascript failed" ]]; then
    echo "osascript failed; check Accessibility permission for your terminal app" >&2
  fi

  sleep "${interval}"
done
