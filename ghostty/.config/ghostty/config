# Ghostty config
# Stowed with: stow ghostty  ->  ~/.config/ghostty/config

# Don't prompt "Close Tab? The terminal still has a running process."
# when closing a surface/tab/window that has a running process.
confirm-close-surface = false

# Font size in points. Ghostty's default is 13; bump it up by 2.
font-size = 14

# Keep the macOS titlebar (so the close/minimize/zoom buttons stay), but
# blend it into the terminal background instead of removing it.
macos-titlebar-style = transparent

# Pin a static, blank window title so the titlebar doesn't show the cwd/path.
# (Without this, Ghostty reports the shell's current directory up top.)
title = " "

# Hide the macOS document "proxy icon" (the little folder/file icon in the
# titlebar that represents the cwd and can be dragged). "title" hides the text;
# this hides the icon next to it.
macos-titlebar-proxy-icon = hidden

# Block cursor instead of the default "bar" (the Microsoft-Word-looking beam)
cursor-style = block

# Keep it solid (set to true if you want it to blink)
cursor-style-blink = false

# Shell integration can reset the cursor to a bar at the prompt.
# Disabling the cursor feature keeps the block everywhere. The SSH features
# prevent remote hosts from seeing xterm-ghostty without terminfo support.
shell-integration-features = no-cursor,ssh-env,ssh-terminfo

# Treat the Option key as Alt/Meta so tmux's M-* bindings work
# (Option+arrows for pane nav, M-d detach, M-a picker, M-n new claude, etc.).
# Tradeoff: you lose Option-based accent composition (é, ñ ...). Switch to
# "right" if you want to keep the LEFT Option key for typing accents.
macos-option-as-alt = true

# Emit a distinct Shift+Enter sequence so TUIs can bind it separately from Enter.
keybind = shift+enter=csi:13;2u

# Don't dim the unfocused split. Ghostty defaults to 0.7, which fades the
# terminal split whenever tmux-nav (the other split) is focused. Keep both
# splits at full opacity so the terminal stays fully readable while navigating.
unfocused-split-opacity = 1
